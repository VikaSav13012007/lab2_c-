void replace_chars_array(array<string, SIZE>& arr) {
    auto start = high_resolution_clock::now();
    string chars = "AEIOUaeiouy";
    for (int i = 0; i < SIZE; i++) {
        transform(arr[i].begin(), arr[i].end(), arr[i].begin(), [chars](char c) {
            for (char charr : chars) {
        if (c == charr) return '*';
    }
    return c;
    });
    }
    auto end = high_resolution_clock::now();
    auto duration = duration_cast<nanoseconds>(end - start).count();
    cout << "замена гласных в array: " << duration << " нс" << endl;
}

