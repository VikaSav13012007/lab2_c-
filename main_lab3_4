const int SIZE = 50;

string random_word() {
    static const string charset = "abcdefghijklmnopqrstuvwxyz";
    int length = (rand() % 10) + 3;
    string result;
    result.resize(length);
    for (int i = 0; i < length; i++) {
        result[i] = charset[rand() % charset.length()];
    }
    result[0] = toupper(result[0]);
    return result;
}

void input_array(array<string, SIZE>& arr) {
    for (int i = 0; i < SIZE; i++) {
        arr[i] = random_word();
    }
}

void input_vector(vector<string>& vec) {
    for (int i = 0; i < SIZE; i++) {
        vec.push_back(random_word());
    }
}

void input_list(list<string>& lst) {
    for (int i = 0; i < SIZE; i++) {
        lst.push_back(random_word());
    }
}

void find_a_words_array(array<string, SIZE>& arr) {
    auto start = high_resolution_clock::now();
    vector<string> words_with_start_a;
    auto it = arr.begin();
    while ((it = find_if(it, arr.end(), [](const string& s) { return s[0] == 'A'; })) != arr.end()) {
        words_with_start_a.push_back(*it);
        ++it;
    }
    auto end = high_resolution_clock::now();
    auto duration = duration_cast<nanoseconds>(end - start).count();
    cout << "поиск слов на 'A' в array: " << duration << " нс, найдено: " << words_with_start_a.size() << endl;
}

