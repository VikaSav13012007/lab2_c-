void longest_word_array(array<string, SIZE>& arr) {
    auto start = high_resolution_clock::now();
    auto it = max_element(arr.begin(), arr.end(), [](string& word1, string& word2) {
        return word1.length() < word2.length();
    });
    auto end = high_resolution_clock::now();
    auto duration = duration_cast<nanoseconds>(end - start).count();
    cout << "самое длинное слово в array: " << *it << " длина " << (*it).length()<< ", время: " << duration << " нс" << endl;
}

